object alambiqueVeloz{
    var combustible = 21
    method combustible() = combustible
    method esRapido() = true

    method gastarCombustible(){
        combustible -= 20
    }
}

object superChatarraEspacial{
    var cañones = 80
    method combustible() = cañones
    method esRapido() = false
     method gastarCombustible(){
        cañones -= 20
    }
}

